; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

_global_script_classes=[ {
"base": "Control",
"class": "MainWindow",
"language": "GDScript",
"path": "res://Resources/Core/Scripts/Window.gd"
} ]
_global_script_class_icons={
"MainWindow": ""
}

[application]

config/name="KoDansu"
config/description="Konata is back on modern desktop!"
run/main_scene="res://Resources/Core/Scenes/Window.tscn"
boot_splash/image="res://Resources/Textures/Icons/icon.png"
boot_splash/bg_color=Color( 0, 0, 0, 0 )
config/icon="res://Resources/Textures/Icons/icon.png"
config/windows_native_icon="res://Resources/Textures/Icons/icon.ico"

[display]

window/size/width=310
window/size/height=220
window/size/resizable=false
window/size/always_on_top=true
window/per_pixel_transparency/allowed=true
window/per_pixel_transparency/enabled=true
window/stretch/mode="2d"
window/stretch/aspect="expand"

[gui]

common/drop_mouse_on_gui_input_disabled=true

[mono]

project/assembly_name="KoDansu"

[physics]

common/enable_pause_aware_picking=true

[rendering]

viewport/transparent_background=true
environment/default_environment="res://default_env.tres"
